# NoFomo — Environment Variables
# Copy this file to .env and fill in real values. .env is gitignored.

# === AI Council (v1.1 — multi-model debate) ===
# Used by the server-side Council Orchestrator (Supabase Edge Function).
# Never exposed to the iOS client. Free-tier users will hit the 4h-delayed
# cached verdicts; Pro/Annual users get the live 3-model debate.

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# === Supabase ===
# Service-role key is server-side only. Never put this in the iOS bundle.
# The anon key lives in Services/SupabaseService.swift (anon-tier is OK to ship).
SUPABASE_URL=https://lmgphebvungyqsnqitcg.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# === App Store Connect / RevenueCat (post-launch) ===
APP_STORE_CONNECT_API_KEY_ID=
APP_STORE_CONNECT_API_ISSUER_ID=
APP_STORE_CONNECT_API_KEY_PATH=
REVENUECAT_PUBLIC_API_KEY=

# === Third-party data (post-launch) ===
# Polygon for real-time prices (Pro tier)
POLYGON_API_KEY=
# Tavily / Brave for deep-research news crawl
TAVILY_API_KEY=
BRAVE_API_KEY=
