# NoFomo Radar Server — required environment variables

# LLM Providers (all three needed for council)
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-sonnet-4-5
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_MODEL=deepseek-chat
GEMINI_API_KEY=...
GEMINI_MODEL=gemini-2.5-pro

# Supabase (service_role key required for writing to radar_opportunities)
SUPABASE_URL=https://lmgphebvungyqsnqitcg.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb-...

# Brave Search API (for web research tool)
BRAVE_API_KEY=...

# Optional — stock price data (falls back to web search if unset)
POLYGON_API_KEY=

# Server
PORT=3001

# --- Alpha Source API Bases (all free, no keys needed) ---
# TIER 1
USPTO_API_BASE=https://api.patentsview.org/patents/query
INDEED_API_BASE=https://www.indeed.com/jobs
SEC_EDGAR_BASE=https://www.sec.gov/cgi-bin/browse-edgar

# TIER 2
SEEKING_ALPHA_BASE=https://seekingalpha.com
HINDENBURG_BASE=https://hindenburgresearch.com

# TIER 3
FDA_API_BASE=https://api.fda.gov
FCC_API_BASE=https://www.fcc.gov
FAA_API_BASE=https://www.faa.gov
