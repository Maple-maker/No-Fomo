# NoFomo Radar Server — required environment variables

# LLM Providers (all three needed for council)
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-sonnet-4-5
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_MODEL=deepseek-chat
GEMINI_API_KEY=...
GEMINI_MODEL=gemini-2.5-pro

# Supabase (service_role key required for writing to radar_opportunities)
SUPABASE_URL=https://jmtkygwvmrolfvwueggs.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb-...

# Brave Search API (for real-time web research)
BRAVE_API_KEY=...

# Exa.ai (neural semantic search for discovery queries)
EXA_API_KEY=...

# Grok / xAI (narrative velocity / market intelligence)
GROK_API_KEY=...
GROK_MODEL=grok-2

# Quiver Quant (congressional trading, insider trades, news headlines, gov contracts, events)
QUIVER_API_KEY=

# SAM.gov (federal contract opportunities from DoD, DARPA, NASA, DOE, DHS)
# Register at https://open.gsa.gov/apis/sam/
SAM_API_KEY=

# Optional — stock price data (falls back to web search if unset)
POLYGON_API_KEY=

# Data source base URLs (no API keys required)
USPTO_API_BASE=https://api.patentsview.org/patents/query
SEC_EDGAR_BASE=https://data.sec.gov/submissions

# Server
PORT=3001
