{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.ts"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "api/index.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/radar/cron?secret=nofomo-cron-dev",
      "schedule": "0 15 * * *"
    }
  ]
}
